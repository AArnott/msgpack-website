{
  "name": "msgpack-website",
  "version": "1.0.0",
  "private": true,
  "description": "MessagePack website - modernized TypeScript + Node build",
  "scripts": {
    "generate": "tsx src/update-index.ts",
    "generate:cached": "tsx src/update-index.ts --use-cache",
    "start": "tsx src/update-server.ts",
    "dev": "tsx watch src/update-server.ts",
    "build": "npm run generate"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.0",
    "cheerio": "^1.2.0",
    "express": "^5.0.0",
    "fs-extra": "^11.1.1",
    "js-yaml": "^5.0.0",
    "markdown-it": "^14.0.0",
    "nunjucks": "^3.2.4"
  },
  "devDependencies": {
    "typescript": "^7.0.0",
    "@types/express": "^5.0.0",
    "@types/fs-extra": "^11.0.0",
    "@types/js-yaml": "^4.0.5",
    "@types/markdown-it": "^14.0.0",
    "@types/node": "^24.0.0",
    "@types/nunjucks": "^3.2.6",
    "tsx": "^4.23.0"
  }
}
